# XPAC Environment Configuration
# Copy this file to .env and fill in your values

# Backend server port (default: 3001)
PORT=3001

# NVIDIA NIM API key for AI chat feature
# Get yours at: https://build.nvidia.com/
# Required for AI assistant functionality
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# Allowed CORS origin (default: http://localhost:5173)
# In production, set this to your deployed frontend URL
CORS_ORIGIN=http://localhost:5173
