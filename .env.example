# XPAC Environment Configuration
# Copy this file to .env and fill in your values

# Backend server port (default: 3001)
PORT=3001

# NVIDIA NIM API key for AI chat feature
# Get yours at: https://build.nvidia.com/
# Required for AI assistant functionality
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# Allowed CORS origin (default: http://localhost:5173)
# In production, set this to your deployed frontend URL
CORS_ORIGIN=http://localhost:5173

# JWT secrets (REQUIRED - generate strong random strings)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Node environment: development | production
NODE_ENV=development

# Frontend URL used in email links (default: http://localhost:5173)
APP_URL=http://localhost:5173

# SMTP / Email configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@xpac.io

# Cloud storage (optional - local filesystem used by default)
# Set USE_CLOUD_STORAGE=true to use S3/R2 for file uploads
USE_CLOUD_STORAGE=false
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_URL=
